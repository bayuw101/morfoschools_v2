  "private": true,
  "scripts": {
    "dev": "node scripts/next-safe.mjs dev",
    "build": "node scripts/next-safe.mjs build",
    "start": "node scripts/next-safe.mjs start",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
