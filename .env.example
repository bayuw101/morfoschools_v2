# Morfoschools local development environment
# Safe placeholders only. Do not commit real secrets.

COMPOSE_PROJECT_NAME=morfoschools

# Frontend
FRONTEND_PORT=1666
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Backend
BACKEND_PORT=8080
APP_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgres://morfoschools:change-me@pgbouncer:5432/morfoschools?sslmode=disable
VALKEY_URL=redis://valkey:6379/0
NATS_URL=nats://nats:4222

# PostgreSQL / PgBouncer
POSTGRES_DB=morfoschools
POSTGRES_USER=morfoschools
POSTGRES_PASSWORD=change-me
PGBOUNCER_POOL_MODE=transaction

# Optional analytics profile
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
